# ──────────────────────────────────────────────
#  MediScan AI — Environment Variables
#  1. Copy this file:   cp .env.example .env
#  2. Fill in values below
#  3. NEVER commit .env to GitHub
# ──────────────────────────────────────────────

# Your GitHub Personal Access Token
# How to get it:
#   github.com → Settings → Developer settings
#   → Personal access tokens → Fine-grained tokens → Generate new token
#   (No special scopes needed for GitHub Models access)
GITHUB_API_KEY=your_github_pat_here

# Optional app settings (defaults shown)
APP_ENV=development
MAX_FILE_SIZE_MB=10
GRADIO_SERVER_PORT=7860
GRADIO_SHARE=False
