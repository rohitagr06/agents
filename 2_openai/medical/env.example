# ──────────────────────────────────────────────
#  MediScan AI — Environment Variables
#  1. Copy this file:   cp .env.example .env
#  2. Fill in values below
#  3. NEVER commit .env to GitHub or HuggingFace
# ──────────────────────────────────────────────

# ─────────────────────────────────────────────────────────────
#  REQUIRED — GitHub Models API Key
#
#  How to get it (free, no credit card needed):
#    1. Go to github.com → Settings → Developer settings
#    2. Personal access tokens → Fine-grained tokens
#    3. Click "Generate new token"
#    4. Give it any name (e.g. "mediscan-ai")
#    5. No special scopes needed — click Generate
#    6. Copy the token and paste it below
#
#  For HuggingFace Spaces:
#    Do NOT put the key here — add it as a Space Secret instead:
#    Space → Settings → Repository secrets → New secret
#    Name: GITHUB_API_KEY   Value: your_token_here
# ─────────────────────────────────────────────────────────────

GITHUB_API_KEY=your_github_pat_here

# ─────────────────────────────────────────────────────────────
#  OPTIONAL — App Settings
#  These have sensible defaults — only change if needed
# ─────────────────────────────────────────────────────────────

# Environment: "development" or "production"
APP_ENV=development

# Maximum upload file size in MB (default: 10)
MAX_FILE_SIZE_MB=10

# Gradio server port (default: 7860)
GRADIO_SERVER_PORT=7860

# Set to True to generate a public share link via Gradio
# Useful for quick demos — not needed for HuggingFace Spaces
GRADIO_SHARE=False
